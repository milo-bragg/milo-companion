    "lint": "eslint . --ext .ts,.tsx",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const dir=path.join(__dirname,'node_modules','hermes-compiler');if(!fs.existsSync(dir)){fs.mkdirSync(dir,{recursive:true});fs.writeFileSync(path.join(dir,'package.json'),JSON.stringify({name:'hermes-compiler',version:'0.0.1',description:'Stub for RN 0.79 + Expo SDK 55 compatibility'}),'utf8');}\""
  },
