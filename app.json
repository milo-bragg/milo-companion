{
  "expo": {
    "name": "Milo Companion",
    "slug": "milo-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.openclaw.milo.companion",
      "appleTeamId": "28NBCD6AWG",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Milo Companion uses the microphone for voice input.",
        "NSSpeechRecognitionUsageDescription": "Milo Companion uses speech recognition to transcribe your voice messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "ai.openclaw.milo.companion",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "scheme": "milo-companion",
    "extra": {
      "eas": {
        "projectId": "904df7b0-8cea-4368-bec7-cb48e2a57982"
      }
    },
    "owner": "milo.bragg.ai"
  }
}
